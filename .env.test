# Loaded automatically by Vite/Vitest when NODE_ENV=test (i.e. during `npm run test`).
# These are placeholder values so the Firebase client plugin can initialise without
# throwing `auth/invalid-api-key` while running unit tests. They never reach a real
# Firebase project. DO NOT put real credentials here.
VITE_FIREBASE_API_KEY=test-api-key
VITE_FIREBASE_AUTH_DOMAIN=test.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=test-project
VITE_FIREBASE_STORAGE_BUCKET=test.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=0
VITE_FIREBASE_APP_ID=1:0:web:0
